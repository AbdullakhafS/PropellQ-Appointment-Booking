{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PropellQ: Stop API on 8000",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/stop-api-locks.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "PropellQ: Prepare API Debug",
      "dependsOn": [
        "PropellQ: Stop API on 8000",
        "PropellQ: Build API"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "PropellQ: Build API",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/PropelIQ.Api/PropelIQ.Api.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "PropellQ: Run Application",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/PropelIQ.Api/PropelIQ.Api.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ASPNETCORE_URLS": "http://propeliq.localhost:8000"
        }
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^ERROR",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building",
          "endsPattern": "Now listening on:"
        }
      }
    }
  ]
}
