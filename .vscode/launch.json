{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PropellQ API (.NET)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "PropellQ: Prepare API Debug",
      "program": "${workspaceFolder}/src/PropelIQ.Api/bin/Debug/net9.0/PropelIQ.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/PropelIQ.Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(http://propeliq\\.localhost:\\d+)",
        "uriFormat": "%s"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://propeliq.localhost:0"
      }
    }
  ]
}
